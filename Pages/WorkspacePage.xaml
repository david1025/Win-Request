<Page
    x:Class="WinRequest.Pages.WorkspacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="using:CommunityToolkit.WinUI.Controls"
    xmlns:controls="using:WinRequest.Controls"
    xmlns:converters="using:WinRequest.Converters"
    NavigationCacheMode="Required"
    Background="Transparent">

    <Page.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource WorkbenchPanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource WorkbenchStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource DefaultTextBoxStyle}">
            <Setter Property="Background" Value="{StaticResource WorkbenchControlBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource WorkbenchStrokeBrush}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="IsSpellCheckEnabled" Value="False" />
            <Setter Property="IsTextPredictionEnabled" Value="False" />
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource DefaultComboBoxStyle}">
            <Setter Property="Background" Value="{StaticResource WorkbenchControlBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource WorkbenchStrokeBrush}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="MinHeight" Value="28" />
        </Style>

        <Style x:Key="TreeNodeActionButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="MinWidth" Value="22" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="CompactTreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="EmptyCommandButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="ShortcutKeyStyle" TargetType="Border">
            <Setter Property="Background" Value="#0F000000" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Margin" Value="3,0,0,0" />
        </Style>

        <Style x:Key="RailButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="5,2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="BodySegmentButtonStyle" TargetType="ToggleButton">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource WorkbenchStrokeBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <SolidColorBrush x:Key="GetMethodBrush" Color="#16A34A" />
        <SolidColorBrush x:Key="PostMethodBrush" Color="#D97706" />
        <SolidColorBrush x:Key="PutMethodBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="DeleteMethodBrush" Color="#DC2626" />
        <SolidColorBrush x:Key="PatchMethodBrush" Color="#9333EA" />
        <SolidColorBrush x:Key="DefaultMethodBrush" Color="#64748B" />

        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <converters:MethodToBrushConverter x:Key="MethodToBrushConverter" />
        <converters:HistoryNodeTextConverter x:Key="HistoryNodeTextConverter" />
        <converters:HistoryNodeMethodBrushConverter x:Key="HistoryNodeMethodBrushConverter" />

        <DataTemplate x:Key="TreeNodeTemplate">
            <Grid MinHeight="22"
                  Padding="0"
                  Background="Transparent"
                  PointerEntered="TreeNode_PointerEntered"
                  PointerExited="TreeNode_PointerExited">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            Spacing="5"
                            VerticalAlignment="Center"
                            MinWidth="0">
                    <FontIcon Glyph="&#xE8B7;"
                              FontSize="12"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              Visibility="{Binding Content.IsFolder, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Border CornerRadius="4"
                            Padding="4,0"
                            MinWidth="34"
                            Background="{Binding Content.Request.Method, Converter={StaticResource MethodToBrushConverter}}"
                            Visibility="{Binding Content.IsFolder, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding Content.Request.Method}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Center" />
                    </Border>
                    <TextBlock Text="{Binding Content.Name}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <StackPanel x:Name="NodeActionPanel"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="2"
                            Visibility="Collapsed">
                    <Button x:Name="NodeAddButton"
                            Tag="{Binding Content}"
                            Click="NodeAddButton_Click"
                            ToolTipService.ToolTip="New request"
                            Style="{StaticResource TreeNodeActionButtonStyle}">
                        <FontIcon Glyph="&#xE710;" FontSize="10" />
                    </Button>
                    <Button Tag="{Binding Content}"
                            Click="NodeMoreButton_Click"
                            ToolTipService.ToolTip="More"
                            Style="{StaticResource TreeNodeActionButtonStyle}">
                        <FontIcon Glyph="&#xE712;" FontSize="10" />
                    </Button>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <MenuFlyout x:Key="TreeNodeFlyout">
            <MenuFlyoutItem x:Name="FlyoutNewRequest" Text="New request" Icon="Add" Click="ContextAddRequest_Click" />
            <MenuFlyoutItem x:Name="FlyoutNewFolder" Text="New folder" Click="ContextAddSubFolder_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE8F4;" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutSeparator x:Name="FlyoutNewSeparator" />
            <MenuFlyoutItem Text="Rename" Click="ContextRename_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE8AC;" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutItem Text="Duplicate request" Click="ContextDuplicate_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE8C8;" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="Delete" Click="ContextDelete_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE74D;" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
        </MenuFlyout>

        <MenuFlyout x:Key="TabContextMenu">
            <MenuFlyoutItem Text="Close" Click="TabContext_Close_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE711;" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutItem Text="Close others" Click="TabContext_CloseOthers_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE89A;" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="Close tabs to the left" Click="TabContext_CloseLeft_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE76B;" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutItem Text="Close tabs to the right" Click="TabContext_CloseRight_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE76C;" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="Close all" Click="TabContext_CloseAll_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE89A;" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
        </MenuFlyout>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="260" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <NavigationView x:Name="MainNav"
                        Grid.Column="0"
                        PaneDisplayMode="LeftCompact"
                        IsPaneOpen="False"
                        OpenPaneLength="220"
                        CompactModeThresholdWidth="0"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="True"
                        AlwaysShowHeader="False"
                        Background="Transparent"
                        SelectionChanged="MainNav_SelectionChanged">
            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
                <SolidColorBrush x:Key="NavigationViewContentGridBackground" Color="Transparent" />
                <SolidColorBrush x:Key="NavigationViewPaneBorderBrush" Color="Transparent" />
                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent" />
                <Thickness x:Key="NavigationViewPaneBorderThickness">0</Thickness>
                <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
            </NavigationView.Resources>
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="CollectionsNavItem"
                                    Content="Collections"
                                    Tag="collections"
                                    ToolTipService.ToolTip="Collections">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B7;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="EnvironmentsNavItem"
                                    Content="Environments"
                                    Tag="environments"
                                    ToolTipService.ToolTip="Environments">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE707;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="HistoryNavItem"
                                    Content="History"
                                    Tag="history"
                                    ToolTipService.ToolTip="History">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE81C;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Border Background="{StaticResource WorkbenchSidebarBrush}"
                    BorderBrush="{StaticResource WorkbenchStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,4,4">
            <Grid>
                <Grid x:Name="CollectionsSidebarPanel" Padding="4,8,8,10" RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="6" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RequestSearchBox"
                                 Height="32"
                                 PlaceholderText="Search Collections"
                                 TextChanged="RequestSearchBox_TextChanged" />
                        <Button Grid.Column="1"
                                ToolTipService.ToolTip="Add"
                                Style="{ThemeResource AccentButtonStyle}"
                                MinWidth="32"
                                Height="32"
                                Padding="8,4">
                            <FontIcon Glyph="&#xE710;" FontSize="13" />
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                    <MenuFlyoutItem Text="New request" Icon="Add" Click="AddRequestButton_Click" />
                                    <MenuFlyoutItem Text="New folder" Click="AddFolderButton_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8F4;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="New collection" Click="AddCollectionButton_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8F4;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Delete current collection" Click="DeleteCollectionButton_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE74D;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="Import Swagger / OpenAPI" Click="ImportSwaggerButton_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8E5;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Import Postman" Click="ImportPostmanButton_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8E5;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>

                    <TreeView x:Name="RequestTreeView"
                              Grid.Row="1"
                              Padding="0,2,0,0"
                              ItemInvoked="RequestTreeView_ItemInvoked"
                              RightTapped="RequestTreeView_RightTapped"
                              CanDragItems="False"
                              CanReorderItems="False"
                              ItemContainerStyle="{StaticResource CompactTreeViewItemStyle}"
                              ItemTemplate="{StaticResource TreeNodeTemplate}" />
                </Grid>

                <Grid x:Name="EnvironmentsSidebarPanel"
                      Visibility="Collapsed"
                      Padding="4,8,8,10"
                      RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="6" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Environments"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Padding="4,0" />
                        <Button Grid.Column="1"
                                Click="AddEnvironmentButton_Click"
                                ToolTipService.ToolTip="New environment"
                                Style="{ThemeResource AccentButtonStyle}"
                                MinWidth="32"
                                Height="32"
                                Padding="8,4">
                            <FontIcon Glyph="&#xE710;" FontSize="13" />
                        </Button>
                    </Grid>

                    <ListView x:Name="EnvironmentListView"
                              Grid.Row="1"
                              SelectionChanged="EnvironmentListView_SelectionChanged"
                              Padding="0,2,0,0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8,6" ColumnSpacing="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <Button Grid.Column="1"
                                            Tag="{Binding}"
                                            ToolTipService.ToolTip="More"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="4,2"
                                            MinWidth="24"
                                            MinHeight="24">
                                        <FontIcon Glyph="&#xE712;" FontSize="10" />
                                        <Button.Flyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="Rename" Tag="{Binding}" Click="EnvironmentMenuRename_Click">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE70F;" /></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="Duplicate" Tag="{Binding}" Click="EnvironmentMenuDuplicate_Click">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem Text="Delete" Tag="{Binding}" Click="EnvironmentMenuDelete_Click">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" /></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <Grid x:Name="HistorySidebarPanel"
                      Visibility="Collapsed"
                      Padding="10,8,8,10"
                      RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBox x:Name="HistorySearchBox"
                             Height="32"
                             PlaceholderText="Search History"
                             TextChanged="HistorySearchBox_TextChanged" />
                    <TreeView x:Name="HistoryTreeView"
                              Grid.Row="1"
                              ItemInvoked="HistoryTreeView_ItemInvoked"
                              CanDragItems="False"
                              CanReorderItems="False"
                              Padding="0,4,0,0">
                        <TreeView.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="26">
                                    <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center"
                                                Visibility="{Binding Content.IsFolder, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <FontIcon Glyph="&#xE8B7;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding Content, Converter={StaticResource HistoryNodeTextConverter}, ConverterParameter=DateLabel}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Content, Converter={StaticResource HistoryNodeTextConverter}, ConverterParameter=CountDisplay}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                                                Visibility="{Binding Content.IsFolder, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <Border CornerRadius="3" Padding="4,1" MinWidth="36"
                                                Background="{Binding Content, Converter={StaticResource HistoryNodeMethodBrushConverter}}">
                                            <TextBlock Text="{Binding Content, Converter={StaticResource HistoryNodeTextConverter}, ConverterParameter=Method}" FontSize="10" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="{Binding Content, Converter={StaticResource HistoryNodeTextConverter}, ConverterParameter=Url}" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="180" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>

                <Grid x:Name="SettingsSidebarPanel"
                      Visibility="Collapsed"
                      Padding="10,8,8,10"
                      RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <NavigationViewItem Content="Settings"
                                        Icon="Setting"
                                        IsSelected="True"
                                        Height="32"
                                        Padding="8,0" />
                    <StackPanel Grid.Row="1" Padding="8,6" Spacing="8">
                        <Button Content="Open settings page"
                                Click="OpenSettingsSidebarButton_Click"
                                HorizontalAlignment="Stretch" />
                        <TextBlock Text="Theme, font and update options live in Settings."
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Grid>
            </Border>
        </NavigationView>

        <ui:GridSplitter Grid.Column="1" Width="8" Background="Transparent" />

        <Grid x:Name="RequestEditorArea" Grid.Column="2" Padding="10,0,10,10" RowSpacing="7">
            <Grid.KeyboardAccelerators>
                <KeyboardAccelerator Key="N" Modifiers="Control" Invoked="NewRequestAccelerator_Invoked" />
                <KeyboardAccelerator Key="O" Modifiers="Control" Invoked="ImportAccelerator_Invoked" />
                <KeyboardAccelerator Key="K" Modifiers="Control" Invoked="FindAccelerator_Invoked" />
            </Grid.KeyboardAccelerators>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="OpenRequestTabHeaderBar" Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TabView x:Name="OpenRequestTabView"
                         IsAddTabButtonVisible="False"
                         CanDragTabs="False"
                         SelectionChanged="OpenRequestTabView_SelectionChanged"
                         TabCloseRequested="OpenRequestTabView_TabCloseRequested"
                         RightTapped="OpenRequestTabView_RightTapped" />
                <Button Grid.Column="1"
                        Click="NewTabButton_Click"
                        ToolTipService.ToolTip="New request"
                        Style="{StaticResource GhostButtonStyle}"
                        Width="36"
                        Height="36"
                        Padding="0"
                        Margin="4,6,0,0"
                        VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE710;" FontSize="13" />
                </Button>
            </Grid>

            <!-- Breadcrumb bar: type switcher + path + editable name + format button -->
            <Grid x:Name="BreadcrumbBar" Grid.Row="1" Padding="4,2" ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Type badge button (click to switch type) -->
                <Button x:Name="BreadcrumbTypeButton"
                        Click="BreadcrumbTypeButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        MinWidth="0"
                        MinHeight="0">
                    <Border x:Name="BreadcrumbTypeBadge"
                            CornerRadius="4"
                            Padding="8,4"
                            Background="#16A34A">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock x:Name="BreadcrumbTypeText"
                                       Text="HTTP"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="White" />
                            <FontIcon Glyph="&#xE70D;" FontSize="9" Foreground="White" />
                        </StackPanel>
                    </Border>
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="HTTP" Tag="Http" Click="BreadcrumbTypeItem_Click" />
                            <MenuFlyoutItem Text="WebSocket" Tag="WebSocket" Click="BreadcrumbTypeItem_Click" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <!-- Collection / folder path (non-editable) -->
                <TextBlock x:Name="BreadcrumbCollectionText"
                           Grid.Column="1"
                           Text=""
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="220" />

                <TextBlock x:Name="BreadcrumbSeparator"
                           Text="/"
                           Grid.Column="2"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           VerticalAlignment="Center" />

                <!-- Request name: TextBlock (click to edit) + hidden TextBox -->
                <Grid Grid.Column="3">
                    <Grid.Resources>
                        <!-- Compact inline-edit style: mirrors CellTextBox vertical-centering technique -->
                        <Style x:Key="NameBoxStyle" TargetType="TextBox">
                            <Setter Property="Foreground" Value="{ThemeResource TextControlForeground}" />
                            <Setter Property="Background" Value="{StaticResource WorkbenchControlBrush}" />
                            <Setter Property="BorderBrush" Value="{StaticResource WorkbenchStrokeBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="CornerRadius" Value="4" />
                            <Setter Property="Padding" Value="6,4,6,5" />
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="MinHeight" Value="26" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Left" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="IsSpellCheckEnabled" Value="False" />
                            <Setter Property="IsTextPredictionEnabled" Value="False" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Grid>
                                            <Border x:Name="BorderElement"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="{TemplateBinding CornerRadius}"
                                                    MinHeight="{TemplateBinding MinHeight}">
                                                <ScrollViewer x:Name="ContentElement"
                                                              Margin="{TemplateBinding BorderThickness}"
                                                              Padding="{TemplateBinding Padding}"
                                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                              IsTabStop="False"
                                                              AutomationProperties.AccessibilityView="Raw" />
                                            </Border>
                                            <TextBlock x:Name="PlaceholderTextContentPresenter"
                                                       Text="{TemplateBinding PlaceholderText}"
                                                       Foreground="{ThemeResource TextControlPlaceholderForeground}"
                                                       Padding="{TemplateBinding Padding}"
                                                       FontFamily="{TemplateBinding FontFamily}"
                                                       FontSize="{TemplateBinding FontSize}"
                                                       IsHitTestVisible="False"
                                                       VerticalAlignment="Center" />
                                            <VisualStateManager.VisualStateGroups>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <VisualState x:Name="Normal" />
                                                    <VisualState x:Name="PointerOver">
                                                        <Storyboard>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderElement" Storyboard.TargetProperty="Background">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource TextControlBackgroundPointerOver}" />
                                                            </ObjectAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </VisualState>
                                                    <VisualState x:Name="Focused">
                                                        <Storyboard>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderElement" Storyboard.TargetProperty="Background">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource TextControlBackgroundFocused}" />
                                                            </ObjectAnimationUsingKeyFrames>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderElement" Storyboard.TargetProperty="BorderBrush">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource TextControlBorderBrushFocused}" />
                                                            </ObjectAnimationUsingKeyFrames>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderElement" Storyboard.TargetProperty="BorderThickness">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="1,1,1,2" />
                                                            </ObjectAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </VisualState>
                                                    <VisualState x:Name="Disabled">
                                                        <Storyboard>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderElement" Storyboard.TargetProperty="Background">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource TextControlBackgroundDisabled}" />
                                                            </ObjectAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </VisualState>
                                                </VisualStateGroup>
                                            </VisualStateManager.VisualStateGroups>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Grid.Resources>

                    <TextBlock x:Name="BreadcrumbNameText"
                               Text=""
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Tapped="BreadcrumbNameText_Tapped"
                               ToolTipService.ToolTip="Click to rename" />
                    <TextBox x:Name="NameBox"
                             Style="{StaticResource NameBoxStyle}"
                             MaxWidth="300"
                             MinWidth="80"
                             Visibility="Collapsed"
                             TextChanged="Editor_TextChanged"
                             LostFocus="NameBox_LostFocus"
                             KeyDown="NameBox_KeyDown" />
                </Grid>

                <!-- Save button (moved from URL bar) -->
                <Button Grid.Column="4"
                        Click="SaveButton_Click"
                        ToolTipService.ToolTip="Save"
                        Style="{StaticResource GhostButtonStyle}"
                        Height="28"
                        Width="34">
                    <FontIcon Glyph="&#xE74E;" FontSize="14" />
                </Button>
            </Grid>

            <Border Grid.Row="2"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="8,7">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="MethodColumn" Width="92" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="MethodComboBox"
                              SelectionChanged="MethodComboBox_SelectionChanged"
                              Background="#FFE8F5E9"
                              BorderBrush="#3316A34A"
                              Foreground="#16A34A"
                              Height="34"
                              CornerRadius="6">
                        <ComboBoxItem Content="GET" Foreground="{StaticResource PositiveStatusBrush}" IsSelected="True" />
                        <ComboBoxItem Content="POST" Foreground="{StaticResource WarningStatusBrush}" />
                        <ComboBoxItem Content="PUT" />
                        <ComboBoxItem Content="PATCH" Foreground="#C084FC" />
                        <ComboBoxItem Content="DELETE" Foreground="{StaticResource DangerStatusBrush}" />
                        <ComboBoxItem Content="HEAD" />
                        <ComboBoxItem Content="OPTIONS" />
                        <ComboBoxItem Content="CONNECT" />
                    </ComboBox>

                    <StackPanel x:Name="WsConnectionStatusPanel"
                                Orientation="Horizontal"
                                Spacing="7"
                                Visibility="Collapsed"
                                VerticalAlignment="Center">
                        <Ellipse x:Name="WsStatusDot"
                                 Width="9"
                                 Height="9"
                                 Fill="#9CA3AF" />
                        <TextBlock x:Name="WsStatusText"
                                   Text="Disconnected"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Hidden TypeComboBox kept for data binding -->
                    <ComboBox x:Name="TypeComboBox"
                              SelectionChanged="TypeComboBox_SelectionChanged"
                              Visibility="Collapsed">
                        <ComboBoxItem Content="HTTP" Tag="Http" IsSelected="True" />
                        <ComboBoxItem Content="WebSocket" Tag="WebSocket" />
                    </ComboBox>

                    <TextBox x:Name="UrlBox"
                             Grid.Column="1"
                             PlaceholderText="https://api.example.com/v1/users?page=1"
                             TextChanged="UrlBox_TextChanged"
                             Height="34" />

                    <Grid Grid.Column="2">
                        <Button x:Name="SendButton"
                                Click="SendButton_Click"
                                Style="{ThemeResource AccentButtonStyle}"
                                Padding="20,6"
                                Height="34"
                                FontWeight="SemiBold">
                            <TextBlock x:Name="SendButtonText" Text="Send" />
                        </Button>
                        <Button x:Name="WsConnectButton"
                                Content="Connect"
                                Click="WsConnectButton_Click"
                                Style="{ThemeResource AccentButtonStyle}"
                                Padding="16,6"
                                Height="34"
                                Visibility="Collapsed" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="8,6,8,8">
                <Grid RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TabView x:Name="RequestConfigTabView"
                             Grid.Row="1"
                             IsAddTabButtonVisible="False"
                             CanDragTabs="False"
                             TabWidthMode="SizeToContent"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch">
                        <TabViewItem Header="Params" IsClosable="False">
                            <controls:KeyValueTable x:Name="QueryTable"
                                                    KeyPlaceholderText="Query parameter name"
                                                    ValuePlaceholderText="Query parameter value"
                                                    DescriptionPlaceholderText="Description" />
                        </TabViewItem>
                        <TabViewItem Header="Headers" IsClosable="False">
                            <controls:KeyValueTable x:Name="HeadersTable"
                                                    KeyPlaceholderText="Header name"
                                                    ValuePlaceholderText="Header value"
                                                    DescriptionPlaceholderText="Description"
                                                    SupportsAutoGeneratedHeaders="True" />
                        </TabViewItem>
                        <TabViewItem x:Name="BodyTabItem" Header="Body" IsClosable="False">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid x:Name="BodyOptionsGrid" Padding="4,4,4,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <ToggleButton x:Name="BodyNoneRadio" Content="none"
                                                      IsChecked="True"
                                                      Checked="BodyTypeRadio_Changed"
                                                      Unchecked="BodyTypeRadio_Unchecked"
                                                      Style="{StaticResource BodySegmentButtonStyle}" />
                                        <ToggleButton x:Name="BodyFormDataRadio" Content="form-data"
                                                      Checked="BodyTypeRadio_Changed"
                                                      Unchecked="BodyTypeRadio_Unchecked"
                                                      Style="{StaticResource BodySegmentButtonStyle}" />
                                        <ToggleButton x:Name="BodyUrlEncodedRadio" Content="x-www-form-urlencoded"
                                                      Checked="BodyTypeRadio_Changed"
                                                      Unchecked="BodyTypeRadio_Unchecked"
                                                      Style="{StaticResource BodySegmentButtonStyle}" />
                                        <ToggleButton x:Name="BodyRawRadio" Content="raw"
                                                      Checked="BodyTypeRadio_Changed"
                                                      Unchecked="BodyTypeRadio_Unchecked"
                                                      Style="{StaticResource BodySegmentButtonStyle}" />
                                        <ToggleButton x:Name="BodyBinaryRadio" Content="binary"
                                                      Checked="BodyTypeRadio_Changed"
                                                      Unchecked="BodyTypeRadio_Unchecked"
                                                      Style="{StaticResource BodySegmentButtonStyle}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Spacing="6">
                                        <ComboBox x:Name="RawFormatComboBox"
                                                  MinWidth="88"
                                                  Visibility="Collapsed"
                                                  SelectionChanged="RawFormatComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Text" Tag="Raw" IsSelected="True" />
                                            <ComboBoxItem Content="JSON" Tag="Json" />
                                            <ComboBoxItem Content="XML" Tag="Xml" />
                                        </ComboBox>
                                        <Button Click="FormatRequestJsonButton_Click"
                                                ToolTipService.ToolTip="Format request body (JSON / XML)"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Height="28"
                                                Visibility="{Binding Visibility, ElementName=RawFormatComboBox}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE943;" FontSize="12" />
                                                <TextBlock Text="Format" FontSize="12" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="SelectFileButton"
                                                Click="SelectBinaryFile_Click"
                                                Visibility="Collapsed"
                                                Padding="8,4">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE838;" FontSize="12" />
                                                <TextBlock Text="Choose file" FontSize="12" />
                                            </StackPanel>
                                        </Button>
                                        <TextBlock x:Name="BinaryFilePathText"
                                                   Visibility="Collapsed"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   MaxWidth="220"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>

                                <Grid x:Name="WsMessageActions"
                                      Padding="4,4,4,8"
                                      Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox MinWidth="92"
                                              SelectedIndex="0"
                                              Height="32">
                                        <ComboBoxItem Content="Text" />
                                        <ComboBoxItem Content="JSON" />
                                    </ComboBox>
                                    <Button Grid.Column="2"
                                            Click="WsSendMessageButton_Click"
                                            Style="{ThemeResource AccentButtonStyle}"
                                            Padding="16,6"
                                            Height="32">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE724;" FontSize="13" />
                                            <TextBlock Text="Send" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <RichEditBox x:Name="BodyBox"
                                                 AcceptsReturn="True"
                                                 TextWrapping="NoWrap"
                                                 FontFamily="Consolas"
                                                 BorderThickness="1"
                                                 BorderBrush="{StaticResource WorkbenchSubtleStrokeBrush}"
                                                 Background="#FFF8F9FA"
                                                 HorizontalAlignment="Stretch"
                                                 VerticalAlignment="Stretch"
                                                 MinHeight="120"
                                                 Padding="10,8"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                 PlaceholderText="JSON / text / WebSocket message"
                                                 TextChanged="BodyBox_TextChanged" />

                                    <controls:KeyValueTable x:Name="FormDataTable"
                                                            SupportsValueKind="True"
                                                            Visibility="Collapsed" />
                                    <controls:KeyValueTable x:Name="UrlEncodedTable" Visibility="Collapsed" />

                                    <StackPanel x:Name="BinaryInfoPanel"
                                                Visibility="Collapsed"
                                                VerticalAlignment="Top"
                                                Padding="12,8"
                                                Spacing="8">
                                        <TextBlock Text="Choose a file to send as the request body."
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <Button Click="SelectBinaryFile_Click" Padding="12,6">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE838;" FontSize="14" />
                                                <TextBlock Text="Browse..." />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </TabViewItem>
                        <TabViewItem x:Name="AuthorizationTabItem" Header="Authorization" IsClosable="False">
                            <TextBlock Text="Authorization settings can be added here."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="8" />
                        </TabViewItem>
                        <TabViewItem Header="Settings" IsClosable="False">
                            <TextBlock Text="Per-request settings can be added here."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="8" />
                        </TabViewItem>
                    </TabView>
                </Grid>
            </Border>

            <ui:GridSplitter Grid.Row="4"
                             Height="7"
                             Background="#15000000"
                             HorizontalAlignment="Stretch" />

            <Border Grid.Row="5"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="8,7,8,8">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ResponseSummaryText"
                                   Text="Response"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="10"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Status:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="ResponseStatusValueText"
                                       Text="-"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="|" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="Time:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="ResponseTimeValueText"
                                       Text="-"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="|" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="Size:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="ResponseSizeValueText"
                                       Text="-"
                                       FontWeight="SemiBold" />
                            <Button Click="FormatResponseJsonButton_Click"
                                    ToolTipService.ToolTip="Format response Body JSON"
                                    Style="{StaticResource GhostButtonStyle}">
                                <FontIcon Glyph="&#xE943;" FontSize="12" />
                            </Button>
                            <Button x:Name="WsClearButton"
                                    Click="WsClearButton_Click"
                                    ToolTipService.ToolTip="Clear messages"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Visibility="Collapsed">
                                <FontIcon Glyph="&#xE74D;" FontSize="13" />
                            </Button>
                            <ProgressRing x:Name="SendProgressRing"
                                          Width="20"
                                          Height="20"
                                          IsActive="False"
                                          Visibility="Collapsed" />
                        </StackPanel>
                    </Grid>

                    <TabView x:Name="ResponseTabView"
                             Grid.Row="1"
                             IsAddTabButtonVisible="False"
                             CanDragTabs="False"
                             TabWidthMode="SizeToContent">
                        <TabViewItem Header="Body" IsClosable="False">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollMode="Auto"
                                          VerticalScrollMode="Auto"
                                          Background="#FFF8F9FA">
                                <RichTextBlock x:Name="ResponseBodyRichTextBlock"
                                               FontFamily="Consolas"
                                               FontSize="13"
                                               IsTextSelectionEnabled="True"
                                               TextWrapping="NoWrap"
                                               Padding="10,8" />
                            </ScrollViewer>
                        </TabViewItem>
                        <TabViewItem Header="Headers" IsClosable="False">
                            <TextBox x:Name="ResponseHeadersBox"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas"
                                     BorderThickness="1"
                                     BorderBrush="{StaticResource WorkbenchSubtleStrokeBrush}"
                                     Background="#FFF8F9FA" />
                        </TabViewItem>
                    </TabView>

                    <ScrollViewer x:Name="WsMessageScrollViewer"
                                  Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="#FFF8F9FA"
                                  Padding="10,8"
                                  Visibility="Collapsed">
                        <StackPanel x:Name="WsMessageList" Spacing="4" />
                    </ScrollViewer>
                </Grid>
            </Border>


            <Grid x:Name="EmptyWorkspacePanel"
                  Grid.Row="0"
                  Grid.RowSpan="6"
                  Visibility="Collapsed"
                  Background="{StaticResource WorkbenchPanelBrush}">
                <StackPanel Width="340"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="18">
                    <Grid Width="112"
                          Height="112"
                          HorizontalAlignment="Center">
                        <Ellipse Fill="#0D000000" />
                        <FontIcon Glyph="&#xE104;"
                                  FontSize="54"
                                  Foreground="#55FFFFFF"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  RenderTransformOrigin="0.5,0.5">
                            <FontIcon.RenderTransform>
                                <RotateTransform Angle="-45" />
                            </FontIcon.RenderTransform>
                        </FontIcon>
                    </Grid>

                    <StackPanel Spacing="2">
                        <Button Click="EmptyCreateNewButton_Click"
                                Style="{StaticResource EmptyCommandButtonStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Create new"
                                           FontSize="18"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Border Style="{StaticResource ShortcutKeyStyle}">
                                        <TextBlock Text="Ctrl" FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Border>
                                    <Border Style="{StaticResource ShortcutKeyStyle}">
                                        <TextBlock Text="N" FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button Click="EmptyImportButton_Click"
                                Style="{StaticResource EmptyCommandButtonStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Import"
                                           FontSize="18"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Border Style="{StaticResource ShortcutKeyStyle}">
                                        <TextBlock Text="Ctrl" FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Border>
                                    <Border Style="{StaticResource ShortcutKeyStyle}">
                                        <TextBlock Text="O" FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button Click="EmptyFindButton_Click"
                                Style="{StaticResource EmptyCommandButtonStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Find in workspace"
                                           FontSize="18"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Border Style="{StaticResource ShortcutKeyStyle}">
                                        <TextBlock Text="Ctrl" FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Border>
                                    <Border Style="{StaticResource ShortcutKeyStyle}">
                                        <TextBlock Text="K" FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Environment editing overlay spanning the full right column -->
        <Grid x:Name="EnvironmentOverlayPanel"
              Grid.Column="2"
              Visibility="Collapsed"
              Padding="10,0,10,10"
              RowSpacing="7">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button x:Name="EnvBackButton"
                        Click="EnvBackButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="8,4"
                        MinWidth="28"
                        MinHeight="28"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="Back to workspace">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                </Button>
                <TextBlock x:Name="EnvTitleText"
                           Grid.Column="1"
                           Text=""
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="2"
                        Click="RenameEnvironmentButton_Click"
                        ToolTipService.ToolTip="Rename"
                        Style="{StaticResource GhostButtonStyle}"
                        VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE8AC;" FontSize="13" />
                </Button>
            </Grid>

            <Border Grid.Row="1"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="0">
                <controls:KeyValueTable x:Name="EnvironmentTable" />
            </Border>
        </Grid>

        <!-- Inline settings overlay spanning the full right column -->
        <ScrollViewer x:Name="SettingsOverlayPanel"
                      Grid.Column="2"
                      Visibility="Collapsed"
                      Background="Transparent">
            <StackPanel Padding="28,12,28,28" Spacing="20" HorizontalAlignment="Stretch">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="SettingsBackButton"
                            Click="SettingsBackButton_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8,4"
                            MinWidth="28"
                            MinHeight="28"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="返回工作区">
                        <FontIcon Glyph="&#xE72B;" FontSize="14" />
                    </Button>
                    <TextBlock Grid.Column="1" Text="设置" Style="{ThemeResource TitleTextBlockStyle}" VerticalAlignment="Center" />
                </Grid>

                <Border Background="{StaticResource WorkbenchPanelBrush}"
                        BorderBrush="{StaticResource WorkbenchStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20,16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="外观" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" MinWidth="200" MaxWidth="400" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="主题" VerticalAlignment="Center" />
                            <ComboBox x:Name="InlineThemeComboBox" Grid.Column="1" SelectionChanged="InlineSettings_Changed">
                                <ComboBoxItem Content="跟随系统" Tag="System" IsSelected="True" />
                                <ComboBoxItem Content="浅色" Tag="Light" />
                                <ComboBoxItem Content="深色" Tag="Dark" />
                            </ComboBox>

                            <TextBlock Grid.Row="1" Text="编辑器字体" VerticalAlignment="Center" />
                            <TextBox x:Name="InlineFontFamilyBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     PlaceholderText="例如 Consolas / Cascadia Mono"
                                     TextChanged="InlineSettingsText_Changed" />

                            <TextBlock Grid.Row="2" Text="文字大小" VerticalAlignment="Center" />
                            <NumberBox x:Name="InlineTextSizeBox"
                                       Grid.Row="2"
                                       Grid.Column="1"
                                       Minimum="9"
                                       Maximum="28"
                                       SmallChange="1"
                                       LargeChange="2"
                                       ValueChanged="InlineTextSizeBox_ValueChanged" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource WorkbenchPanelBrush}"
                        BorderBrush="{StaticResource WorkbenchStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20,16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="更新" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" MinWidth="200" MaxWidth="400" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="GitHub Owner" VerticalAlignment="Center" />
                            <TextBox x:Name="InlineGitHubOwnerBox"
                                     Grid.Column="1"
                                     PlaceholderText="例如 your-name"
                                     TextChanged="InlineSettingsText_Changed" />

                            <TextBlock Grid.Row="1" Text="Repository" VerticalAlignment="Center" />
                            <TextBox x:Name="InlineGitHubRepositoryBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     PlaceholderText="例如 Win-Request"
                                     TextChanged="InlineSettingsText_Changed" />

                            <Button Grid.Row="1"
                                    Grid.Column="2"
                                    Click="InlineCheckUpdateButton_Click"
                                    Style="{ThemeResource AccentButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE895;" FontSize="13" />
                                    <TextBlock Text="检查更新" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <ProgressRing x:Name="InlineUpdateProgressRing" Width="24" Height="24" IsActive="False" Visibility="Collapsed" />
                        <TextBlock x:Name="InlineUpdateResultText"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource WorkbenchPanelBrush}"
                        BorderBrush="{StaticResource WorkbenchStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20,16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="关于" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="Win Request" FontWeight="SemiBold" />
                        <TextBlock Text="一个参考 Swell-SSH 技术框架实现的 WinUI 3 API 调试客户端。" TextWrapping="Wrap" />
                        <TextBlock Text="当前功能包括 Collection、Swagger 导入、HTTP、WebSocket、历史、环境变量、JSON 格式化、主题与字体设置。" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Button Click="InlineSaveSettingsButton_Click"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74E;" FontSize="13" />
                        <TextBlock Text="保存设置" />
                    </StackPanel>
                </Button>

                <TextBlock x:Name="InlineSettingsStatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </ScrollViewer>

        <Grid x:Name="AutoCompleteHost" Grid.ColumnSpan="3" />
    </Grid>
</Page>
