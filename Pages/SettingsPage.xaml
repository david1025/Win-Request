<Page
    x:Class="WinRequest.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Required"
    Background="Transparent">

    <ScrollViewer>
        <StackPanel Padding="28,20,28,28" Spacing="20" MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock Text="设置" Style="{ThemeResource TitleTextBlockStyle}" />

            <Border Background="{StaticResource WorkbenchPanelBrush}"
                    BorderBrush="{StaticResource WorkbenchStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20,16">
                <StackPanel Spacing="12">
                    <TextBlock Text="外观" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <Grid ColumnSpacing="12" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="260" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="主题" VerticalAlignment="Center" />
                        <ComboBox x:Name="ThemeComboBox" Grid.Column="1" SelectionChanged="Settings_Changed">
                            <ComboBoxItem Content="跟随系统" Tag="System" IsSelected="True" />
                            <ComboBoxItem Content="浅色" Tag="Light" />
                            <ComboBoxItem Content="深色" Tag="Dark" />
                        </ComboBox>

                        <TextBlock Grid.Row="1" Text="编辑器字体" VerticalAlignment="Center" />
                        <TextBox x:Name="FontFamilyBox"
                                 Grid.Row="1"
                                 Grid.Column="1"
                                 PlaceholderText="例如 Consolas / Cascadia Mono"
                                 TextChanged="SettingsText_Changed" />

                        <TextBlock Grid.Row="2" Text="文字大小" VerticalAlignment="Center" />
                        <NumberBox x:Name="TextSizeBox"
                                   Grid.Row="2"
                                   Grid.Column="1"
                                   Minimum="9"
                                   Maximum="28"
                                   SmallChange="1"
                                   LargeChange="2"
                                   ValueChanged="TextSizeBox_ValueChanged" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource WorkbenchPanelBrush}"
                    BorderBrush="{StaticResource WorkbenchStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20,16">
                <StackPanel Spacing="12">
                    <TextBlock Text="更新" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <Grid ColumnSpacing="12" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="GitHub Owner" VerticalAlignment="Center" />
                        <TextBox x:Name="GitHubOwnerBox"
                                 Grid.Column="1"
                                 PlaceholderText="例如 your-name"
                                 TextChanged="SettingsText_Changed" />

                        <TextBlock Grid.Row="1" Text="Repository" VerticalAlignment="Center" />
                        <TextBox x:Name="GitHubRepositoryBox"
                                 Grid.Row="1"
                                 Grid.Column="1"
                                 PlaceholderText="例如 Win-Request"
                                 TextChanged="SettingsText_Changed" />

                        <Button Grid.Row="1"
                                Grid.Column="2"
                                Click="CheckUpdateButton_Click"
                                Style="{ThemeResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE895;" FontSize="13" />
                                <TextBlock Text="检查更新" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <ProgressRing x:Name="UpdateProgressRing" Width="24" Height="24" IsActive="False" Visibility="Collapsed" />
                    <TextBlock x:Name="UpdateResultText"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border Background="{StaticResource WorkbenchPanelBrush}"
                    BorderBrush="{StaticResource WorkbenchStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20,16">
                <StackPanel Spacing="8">
                    <TextBlock Text="关于" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Win Request" FontWeight="SemiBold" />
                    <TextBlock Text="一个参考 Swell-SSH 技术框架实现的 WinUI 3 API 调试客户端。" TextWrapping="Wrap" />
                    <TextBlock Text="当前功能包括 Collection、Swagger 导入、HTTP、gRPC、WebSocket、历史、环境变量、JSON 格式化、主题与字体设置。" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Button Click="SaveButton_Click"
                    Style="{ThemeResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74E;" FontSize="13" />
                    <TextBlock Text="保存设置" />
                </StackPanel>
            </Button>

            <TextBlock x:Name="StatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </ScrollViewer>
</Page>
